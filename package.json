{
  "name": "licss",
  "version": "0.1.0",
  "description": "Gulp plugin 'licss' designed for style transformation workflows, and supported .css, .scss, .sass and .pcss files. You can use it to process Bootsrtap framework CSS files (sass version 1.78.0 was used here for the stop warning)",
  "keywords": [
    "gulp",
    "optimize",
    "bundle",
    "minify",
    "purge",
    "styles",
    "css",
    "sass",
    "scss",
    "pcss",
    "bootstrap"
  ],
  "license": "MIT",
  "author": "llcawc",
  "homepage": "https://github.com/llcawc/licss",
  "type": "module",
  "main": "./index.js",
  "exports": "./index.js",
  "types": "./index.d.ts",
  "files": [
    "index.js",
    "index.d.ts",
    "rename.js",
    "rename.d.ts",
    "package.json",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "tsc": "tsc -p ./tsc.json",
    "lint": "eslint ./*.ts",
    "serve": "passerve",
    "assets": "gulp assets",
    "sass": "gulp sass",
    "scss": "gulp scss",
    "pcss": "gulp pcss",
    "css": "gulp css",
    "watch": "gulp monitor"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@types/bootstrap": "^5.2.10",
    "@types/fancy-log": "^2.0.2",
    "@types/gulp": "^4.0.17",
    "@types/node": "^24.2.1",
    "@types/through2": "^2.0.41",
    "@types/vinyl": "^2.0.12",
    "bootstrap": "^5.3.7",
    "clean-css": "^5.3.3",
    "del": "^8.0.0",
    "eslint": "^9.33.0",
    "gulp": "^5.0.1",
    "passerve": "^1.1.6",
    "prettier": "^3.6.2",
    "prettier-plugin-embed": "^0.5.0",
    "prettier-plugin-organize-imports": "^4.2.0",
    "source-map": "^0.7.6",
    "stylelint": "^16.23.1",
    "stylelint-config-clean-order": "^7.0.0",
    "stylelint-config-standard": "^39.0.0",
    "stylelint-config-standard-scss": "^15.0.1",
